.DS_Store
.env
node_modules/

# Local-only runtime artifacts — not part of the project source or CI seed data
.claude/
*.log
*.bak

# Point-by-point shards + their availability index: pure derived output, rebuilt
# from point-by-point-cache.json (the tracked seed) on every pipeline run and
# published straight to _site. One file per match, so committing them would add
# hundreds of churning blobs that nothing reads from git.
pbp/
pbp-index.json
setstats/
setstats-index.json

# Recent-form shards + their availability index: same story — one file per
# player, rebuilt by bsp-pipeline.js on every run from the fixture window it
# already fetches, and served straight from _site.
form/
form-index.json
mcp-cache/
