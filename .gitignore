.DS_Store
.env
node_modules/

# Local-only runtime artifacts — not part of the project source or CI seed data
.claude/
*.log
*.bak

# Point-by-point shards + their availability index: pure derived output, rebuilt
# from point-by-point-cache.json (the tracked seed) on every pipeline run and
# published straight to _site. One file per match, so committing them would add
# hundreds of churning blobs that nothing reads from git.
pbp/
pbp-index.json
setstats/
setstats-index.json

# Recent-form shards + their availability index: same story — one file per
# player, rebuilt by bsp-pipeline.js on every run from the fixture window it
# already fetches, and served straight from _site.
form/
form-index.json

# Odds-movement shards + their availability index: one file per match, split out
# of matches.json by bsp-pipeline.js on every run from the timelines the capturer
# committed there. Derived output — the tracked source of truth stays inline in
# matches.json, where refresh-odds-history.py writes it.
odds/
odds-index.json

# Career-record drill-down shards + their index: one file per player, rebuilt
# every run from the all-tier fixture window plus the TML archive. ~10 MB across
# ~480 players — derived output that would churn the whole set on every run.
career-history/
career-history-index.json
mcp-cache/
tml-cache/
